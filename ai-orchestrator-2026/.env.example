# === AI Orchestrator 2026 — Конфигурация окружения ===

# LLM Router (единый роутер с доступом к нескольким моделям)
LLM_ROUTER_API_KEY=
LLM_ROUTER_BASE_URL=

# Модели для разных задач (smart routing)
MODEL_CREATIVE=gpt-4o
MODEL_MEDIUM=gpt-4o-mini
MODEL_CHEAP=gpt-4o-mini

# База данных для версионирования промптов
DB_PATH=orchestrator.db

# ChromaDB — векторное хранилище
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_PROMPTS=prompt_versions
CHROMA_COLLECTION_KNOWLEDGE=knowledge_base
CHROMA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# DSPy — оптимизатор промптов
DSPY_MODEL=gpt-4o-mini
DSPY_OPTIMIZER_TRAINSET_SIZE=5
DSPY_COMPILED_PROGRAM_PATH=./dspy_compiled/optimizer.json
DSPY_MAX_BOOTSTRAPPED_DEMOS=3
DSPY_MAX_LABELED_DEMOS=2
DSPY_TIMEOUT_SECONDS=120

# OpenTelemetry (наблюдаемость)
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Логирование
LOG_LEVEL=INFO

# Оркестрация
MAX_ITERATIONS=3
APPROVAL_THRESHOLD=0.85
